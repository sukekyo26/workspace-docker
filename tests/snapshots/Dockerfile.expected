# Auto-generated from workspace.toml — do not edit directly.
ARG UBUNTU_VERSION
FROM ubuntu:${UBUNTU_VERSION}

ARG USERNAME
ARG UID
ARG GID

RUN apt-get update && \
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
    curl \
    wget \
    ca-certificates \
    gnupg \
    openssh-client \
    git \
    make \
    sudo \
    vim \
    nano \
    zip \
    unzip \
    tar \
    gzip \
    bzip2 \
    xz-utils \
    tree \
    jq \
    bc \
    less \
    rsync \
    procps \
    iproute2 \
    dnsutils \
    iputils-ping \
    net-tools \
    shellcheck \
    uuid-runtime \
    file \
    patch \
    gettext-base \
    python3 \
    python3-pip \
    python3-venv \
    bash-completion \
    locales \
    build-essential \
    libssl-dev \
    zlib1g-dev \
    libbz2-dev \
    libreadline-dev \
    libsqlite3-dev \
    libncursesw5-dev \
    tk-dev \
    libxml2-dev \
    libxmlsec1-dev \
    libffi-dev \
    liblzma-dev \
    && locale-gen en_US.UTF-8 \
    && apt-get clean \
    && rm -rf /var/lib/apt/lists/* /tmp/* /var/tmp/*

RUN userdel -r ubuntu 2>/dev/null || true && \
    groupdel ubuntu 2>/dev/null || true && \
    groupadd -g ${GID} ${USERNAME} && \
    useradd -m -s /bin/bash -u ${UID} -g ${GID} ${USERNAME} && \
    usermod -aG sudo ${USERNAME} && \
    echo "${USERNAME} ALL=(ALL) NOPASSWD:ALL" > /etc/sudoers.d/${USERNAME} && \
    chmod 0440 /etc/sudoers.d/${USERNAME}

USER ${USERNAME}
WORKDIR /home/${USERNAME}

# Set locale environment variables
ENV LANG=en_US.UTF-8
ENV LANGUAGE=en_US:en
ENV LC_ALL=en_US.UTF-8

# Enable bash completion
RUN echo 'if [ -f /usr/share/bash-completion/bash_completion ]; then' >> ~/.bashrc && \
    echo '  . /usr/share/bash-completion/bash_completion' >> ~/.bashrc && \
    echo 'fi' >> ~/.bashrc


# Prepare volume mount directories with correct ownership
USER root
RUN mkdir -p /home/${USERNAME}/.aws /home/${USERNAME}/.cargo /home/${USERNAME}/.claude /home/${USERNAME}/.config /home/${USERNAME}/.copilot /home/${USERNAME}/.deno /home/${USERNAME}/.proto /home/${USERNAME}/.rustup /home/${USERNAME}/go && \
    chown ${USERNAME}:${USERNAME} /home/${USERNAME}/.aws /home/${USERNAME}/.cargo /home/${USERNAME}/.claude /home/${USERNAME}/.config /home/${USERNAME}/.copilot /home/${USERNAME}/.deno /home/${USERNAME}/.proto /home/${USERNAME}/.rustup /home/${USERNAME}/go
USER ${USERNAME}
# Custom PS1 with Docker container name, user/host, working directory, and git status
RUN echo 'GIT_PS1_SHOWDIRTYSTATE=1' >> ~/.bashrc && \
    echo 'GIT_PS1_SHOWUNTRACKEDFILES=1' >> ~/.bashrc && \
    echo 'GIT_PS1_SHOWUPSTREAM="auto"' >> ~/.bashrc && \
    echo 'PS1='"'"'\\[\\033[01;35m\\][Docker $CONTAINER_SERVICE_NAME]\\[\\033[00m\\] \\[\\033[01;32m\\]\\u@\\h:\\[\\033[01;34m\\]\\w\\[\\033[00m\\]$(__git_ps1 " \\[\\033[01;33m\\](%s)\\[\\033[00m\\]" 2>/dev/null) \\$ '"'"'' >> ~/.bashrc
# proto (multi-language version manager)
RUN curl -fsSL --proto '=https' --tlsv1.2 https://moonrepo.dev/install/proto.sh -o /tmp/install-proto.sh && \
    echo "a536b96a0f770a0f5a808e229777ca5462b4e31e641c530fcdc34d03a15b1ae6  /tmp/install-proto.sh" | sha256sum -c - && \
    bash /tmp/install-proto.sh --no-profile --yes && \
    rm -f /tmp/install-proto.sh && \
    echo 'export PROTO_HOME="$HOME/.proto"' >> ~/.bashrc && \
    echo 'export PATH="$PROTO_HOME/shims:$PROTO_HOME/bin:$PATH"' >> ~/.bashrc
ENV PROTO_HOME="/home/${USERNAME}/.proto"
ENV PATH="$PROTO_HOME/shims:$PROTO_HOME/bin:$PATH"
USER root
# Install Docker CLI (client only, to use host Docker daemon via socket mount)
ARG DOCKER_GID
RUN mkdir -p /etc/apt/keyrings && \
    curl -fsSL --proto '=https' --tlsv1.2 https://download.docker.com/linux/ubuntu/gpg | gpg --dearmor -o /etc/apt/keyrings/docker.gpg && \
    . /etc/os-release && \
    echo "deb [arch=$(dpkg --print-architecture) signed-by=/etc/apt/keyrings/docker.gpg] https://download.docker.com/linux/ubuntu ${VERSION_CODENAME} stable" \
    > /etc/apt/sources.list.d/docker.list && \
    apt-get update && \
    apt-get install -y --no-install-recommends docker-ce-cli docker-compose-plugin && \
    apt-get clean && \
    rm -rf /var/lib/apt/lists/* /tmp/* /var/tmp/* && \
    groupadd -g ${DOCKER_GID} docker 2>/dev/null || groupmod -g ${DOCKER_GID} docker && \
    usermod -aG docker ${USERNAME}
USER ${USERNAME}
# Install AWS CLI v2
RUN ARCH="$(dpkg --print-architecture)" && \
    case "$ARCH" in \
        amd64) CLI_ARCH="x86_64" ;; \
        arm64) CLI_ARCH="aarch64" ;; \
        *) CLI_ARCH="x86_64" ;; \
    esac && \
    curl -fsSL --proto '=https' --tlsv1.2 "https://awscli.amazonaws.com/awscli-exe-linux-${CLI_ARCH}.zip" -o "awscliv2.zip" && \
    unzip awscliv2.zip && \
    sudo ./aws/install && \
    rm -rf aws awscliv2.zip
# Install AWS SAM CLI
RUN ARCH="$(dpkg --print-architecture)" && \
    case "$ARCH" in \
        amd64) DOWNLOAD_ARCH="x86_64" ;; \
        arm64) DOWNLOAD_ARCH="aarch64" ;; \
        *) DOWNLOAD_ARCH="x86_64" ;; \
    esac && \
    echo "Detected architecture: $ARCH -> $DOWNLOAD_ARCH" && \
    curl -fsSL --proto '=https' --tlsv1.2 "https://github.com/aws/aws-sam-cli/releases/latest/download/aws-sam-cli-linux-${DOWNLOAD_ARCH}.zip" -o "aws-sam-cli.zip" && \
    unzip aws-sam-cli.zip -d sam-installation && \
    sudo ./sam-installation/install && \
    rm -rf sam-installation aws-sam-cli.zip
USER root
# Install GitHub CLI
RUN mkdir -p -m 755 /etc/apt/keyrings && \
    curl -fsSL --proto '=https' --tlsv1.2 https://cli.github.com/packages/githubcli-archive-keyring.gpg -o /etc/apt/keyrings/githubcli-archive-keyring.gpg && \
    chmod go+r /etc/apt/keyrings/githubcli-archive-keyring.gpg && \
    echo "deb [arch=$(dpkg --print-architecture) signed-by=/etc/apt/keyrings/githubcli-archive-keyring.gpg] https://cli.github.com/packages stable main" > /etc/apt/sources.list.d/github-cli.list && \
    apt-get update && \
    apt-get install -y --no-install-recommends gh && \
    apt-get clean && \
    rm -rf /var/lib/apt/lists/* /tmp/* /var/tmp/*
USER ${USERNAME}
# Install GitHub Copilot CLI
RUN curl -fsSL --proto '=https' --tlsv1.2 https://gh.io/copilot-install -o /tmp/install-copilot.sh && \
    echo "08a2155a02a2e078cf0ee709b456978ab26badd8b45de7ecc9711f5b92712e30  /tmp/install-copilot.sh" | sha256sum -c - && \
    bash /tmp/install-copilot.sh && \
    rm -f /tmp/install-copilot.sh
# Install Claude Code
RUN curl -fsSL --proto '=https' --tlsv1.2 https://claude.ai/install.sh -o /tmp/install-claude.sh && \
    echo "431889ac7d056f636aaf5b71524666d04c89c45560f80329940846479d484778  /tmp/install-claude.sh" | sha256sum -c - && \
    bash /tmp/install-claude.sh && \
    rm -f /tmp/install-claude.sh
USER root
# Install Zig (required for cargo-lambda cross-compilation)
RUN ARCH="$(dpkg --print-architecture)" && \
    case "$ARCH" in \
        amd64) DOWNLOAD_ARCH="x86_64" ; CHECKSUM="02aa270f183da276e5b5920b1dac44a63f1a49e55050ebde3aecc9eb82f93239" ;; \
        arm64) DOWNLOAD_ARCH="aarch64" ; CHECKSUM="958ed7d1e00d0ea76590d27666efbf7a932281b3d7ba0c6b01b0ff26498f667f" ;; \
        *) DOWNLOAD_ARCH="x86_64" ; CHECKSUM="02aa270f183da276e5b5920b1dac44a63f1a49e55050ebde3aecc9eb82f93239" ;; \
    esac && \
    echo "Detected architecture: $ARCH -> $DOWNLOAD_ARCH" && \
    curl -fsSL --proto '=https' --tlsv1.2 "https://ziglang.org/download/0.15.2/zig-${DOWNLOAD_ARCH}-linux-0.15.2.tar.xz" -o /tmp/zig.tar.xz && \
    echo "${CHECKSUM}  /tmp/zig.tar.xz" | sha256sum -c - && \
    mkdir -p /usr/local/zig && \
    tar -xf /tmp/zig.tar.xz -C /usr/local/zig --strip-components=1 && \
    ln -s /usr/local/zig/zig /usr/local/bin/zig && \
    rm /tmp/zig.tar.xz
USER ${USERNAME}
# Install uv (fast Python package and project manager)
RUN curl -fsSL --proto '=https' --tlsv1.2 https://astral.sh/uv/install.sh -o /tmp/install-uv.sh && \
    echo "7fc46e39cb97290b57169c0c813a17970585ac519139f19006453c99b5f2f45f  /tmp/install-uv.sh" | sha256sum -c - && \
    bash /tmp/install-uv.sh && \
    rm -f /tmp/install-uv.sh && \
    echo 'export PATH="$HOME/.local/bin:$PATH"' >> ~/.bashrc
ENV PATH="/home/${USERNAME}/.local/bin:$PATH"
# Install Rust toolchain via rustup
RUN curl -fsSL --proto '=https' --tlsv1.2 https://sh.rustup.rs -o /tmp/rustup-init.sh && \
    echo "17247e4bcacf6027ec2e11c79a72c494c9af69ac8d1abcc1b271fa4375a106c2  /tmp/rustup-init.sh" | sha256sum -c - && \
    sh /tmp/rustup-init.sh -y --default-toolchain stable --component clippy --component rustfmt && \
    rm -f /tmp/rustup-init.sh && \
    echo '. "$HOME/.cargo/env"' >> ~/.bashrc
ENV PATH="/home/${USERNAME}/.cargo/bin:$PATH"
USER root
# Install Go
RUN ARCH="$(dpkg --print-architecture)" && \
    case "$ARCH" in \
    amd64) CHECKSUM="031f088e5d955bab8657ede27ad4e3bc5b7c1ba281f05f245bcc304f327c987a" ;; \
    arm64) CHECKSUM="a290581cfe4fe28ddd737dde3095f3dbeb7f2e4065cab4eae44dfc53b760c2f7" ;; \
    *) CHECKSUM="031f088e5d955bab8657ede27ad4e3bc5b7c1ba281f05f245bcc304f327c987a" ;; \
    esac && \
    curl -fsSL --proto '=https' --tlsv1.2 "https://go.dev/dl/go1.26.1.linux-${ARCH}.tar.gz" -o /tmp/go.tar.gz && \
    echo "${CHECKSUM}  /tmp/go.tar.gz" | sha256sum -c - && \
    tar -C /usr/local -xzf /tmp/go.tar.gz && \
    rm /tmp/go.tar.gz
ENV GOPATH="/home/${USERNAME}/go"
ENV PATH="/usr/local/go/bin:$GOPATH/bin:$PATH"
# Install lazygit
RUN ARCH="$(dpkg --print-architecture)" && \
    case "$ARCH" in \
        amd64) DOWNLOAD_ARCH="x86_64" ; CHECKSUM="264283f40a40c899d702a338b20622f690221f753f03bac827c1f34e91f516c2" ;; \
        arm64) DOWNLOAD_ARCH="arm64" ; CHECKSUM="a334a6c125169f21942f1a8b02043932575547a6250a1a734d62111efd92aa8f" ;; \
        *) DOWNLOAD_ARCH="x86_64" ; CHECKSUM="264283f40a40c899d702a338b20622f690221f753f03bac827c1f34e91f516c2" ;; \
    esac && \
    curl -fsSL --proto '=https' --tlsv1.2 "https://github.com/jesseduffield/lazygit/releases/download/v0.59.0/lazygit_0.59.0_linux_${DOWNLOAD_ARCH}.tar.gz" -o /tmp/lazygit.tar.gz && \
    echo "${CHECKSUM}  /tmp/lazygit.tar.gz" | sha256sum -c - && \
    tar -xzf /tmp/lazygit.tar.gz -C /usr/local/bin lazygit && \
    rm /tmp/lazygit.tar.gz
USER ${USERNAME}

# create volume mount directories for permission
RUN mkdir -p ~/.local

# Setup persistent bash history
RUN echo 'export HISTFILE=~/.local/state/.bash_history_docker' >> ~/.bashrc && \
    echo 'export HISTSIZE=10000' >> ~/.bashrc && \
    echo 'export HISTFILESIZE=20000' >> ~/.bashrc && \
    mkdir -p ~/.local/state && touch ~/.local/state/.bash_history_docker

# Custom configuration file support (config/.bashrc_custom)
RUN echo '' >> ~/.bashrc && \
    echo '# Load custom configuration from config/.bashrc_custom' >> ~/.bashrc && \
    echo '[ -f "$HOME/workspace/workspace-docker/config/.bashrc_custom" ] && . "$HOME/workspace/workspace-docker/config/.bashrc_custom"' >> ~/.bashrc

WORKDIR /home/${USERNAME}/workspace
