services:
  snapshot-test:
    container_name: ${CONTAINER_SERVICE_NAME}
    build:
      context: .
      args:
        - UBUNTU_VERSION=${UBUNTU_VERSION}
        - USERNAME=${USERNAME}
        - UID=${UID}
        - GID=${GID}
    user: "${UID}:${GID}"
    environment:
      - CONTAINER_SERVICE_NAME=${CONTAINER_SERVICE_NAME}
    volumes:
      # ワークスペース
      - ..:/home/${USERNAME}/workspace

      # 個人設定（ホストと同期）
      - ~/.ssh:/home/${USERNAME}/.ssh

      # .local（永続化）- pipx, uv等のユーザーインストールパッケージ
      - local:/home/${USERNAME}/.local

      # proto（永続化）
      - proto:/home/${USERNAME}/.proto
      # AWS CLI v2（永続化）
      - aws:/home/${USERNAME}/.aws
      # GitHub CLI（永続化）
      - gh-config:/home/${USERNAME}/.config/gh
    ports:
      - "${FORWARD_PORT:-3000}:${FORWARD_PORT:-3000}"
    tty: true

volumes:
  local:
    name: "${CONTAINER_SERVICE_NAME}_local"
  proto:
    name: "${CONTAINER_SERVICE_NAME}_proto"
  aws:
    name: "${CONTAINER_SERVICE_NAME}_aws"
  gh-config:
    name: "${CONTAINER_SERVICE_NAME}_gh-config"

