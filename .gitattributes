# テンプレートファイルを適切な言語に強制指定
templates/Dockerfile.template linguist-language=Dockerfile

*.sh linguist-language=Shell

# Auto detect text files and perform LF normalization
* text=auto

# Shell scripts must use LF
*.sh text eol=lf

# Template files must use LF
*.template text eol=lf

# Markdown files
*.md text

# YAML files
*.yml text eol=lf
*.yaml text eol=lf

# Git config
.gitignore text
.gitattributes text
