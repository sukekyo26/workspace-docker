services:
  {{CONTAINER_SERVICE_NAME}}:
    container_name: {{CONTAINER_SERVICE_NAME}}
    build:
      context: .
      args:
        - USERNAME={{USERNAME}}
        - UID={{UID}}
        - GID={{GID}}
    user: "{{UID}}:{{GID}}"
    volumes:
      # ワークスペース
      - .:/home/{{USERNAME}}/workspace

      # 開発ツール（永続化）
      - pyenv-versions:/home/{{USERNAME}}/.pyenv/versions
      - pip-cache:/home/{{USERNAME}}/.cache/pip
      - volta:/home/{{USERNAME}}/.volta
      - npm-cache:/home/{{USERNAME}}/.npm

      # 個人設定（読み取り専用）
      - ~/.aws:/home/{{USERNAME}}/.aws:ro
      - ~/.gitconfig:/home/{{USERNAME}}/.gitconfig:ro

      # コマンド履歴
      - bash-history:/home/{{USERNAME}}/.bash_history
    ports:
      - "3000:3000"
    tty: true

volumes:
  pyenv-versions:
  pip-cache:
  volta:
  npm-cache:
  bash-history: