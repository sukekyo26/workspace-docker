services:
  {{CONTAINER_SERVICE_NAME}}:
    container_name: ${CONTAINER_SERVICE_NAME}
    build:
      context: .
      args:
        - UBUNTU_VERSION=${UBUNTU_VERSION}
        - USERNAME=${USERNAME}
        - UID=${UID}
        - GID=${GID}
    user: "${UID}:${GID}"
    environment:
      - CONTAINER_SERVICE_NAME=${CONTAINER_SERVICE_NAME}
    volumes:
      # ワークスペース
      - ..:/home/${USERNAME}/workspace

      # 開発ツール（永続化）
      - pip-cache:/home/${USERNAME}/.cache/pip
      - uv-cache:/home/${USERNAME}/.cache/uv
      - uv-python:/home/${USERNAME}/.local/share/uv
      - poetry-cache:/home/${USERNAME}/.cache/pypoetry
      - poetry-data:/home/${USERNAME}/.local/share/pypoetry
      - pyenv:/home/${USERNAME}/.pyenv
      - volta-tools:/home/${USERNAME}/.volta/tools
      - nvm:/home/${USERNAME}/.nvm
      - fnm:/home/${USERNAME}/.local/share/fnm
      - mise-data:/home/${USERNAME}/.local/share/mise
      - mise-cache:/home/${USERNAME}/.cache/mise
      - npm-cache:/home/${USERNAME}/.npm
      - pnpm-cache:/home/${USERNAME}/.cache/pnpm
      - pnpm-store:/home/${USERNAME}/.local/share/pnpm

      # 個人設定（読み取り専用）
      - ~/.gitconfig:/home/${USERNAME}/.gitconfig:ro
      - ~/.ssh:/home/${USERNAME}/.ssh:ro

      # AWS（永続化）
      - aws:/home/${USERNAME}/.aws

      # GitHub CLI（永続化）
      - gh-config:/home/${USERNAME}/.config/gh

      # bash履歴（永続化）
      - bash-history:/home/${USERNAME}/.docker_history
    ports:
      - "3000:3000"
    tty: true

volumes:
  pip-cache:
  uv-cache:
  uv-python:
  poetry-cache:
  poetry-data:
  pyenv:
  volta-tools:
  nvm:
  fnm:
  mise-data:
  mise-cache:
  npm-cache:
  pnpm-cache:
  pnpm-store:
  aws:
  gh-config:
  bash-history:
